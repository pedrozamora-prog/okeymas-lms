{
  "name": "yelau-fit-lms",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.5.4",
    "prettier": "^3.3.3",
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "unrs-resolver", "@prisma/engines", "prisma"]
  }
}
